# Device
device = "cuda" if torch.cuda.is_available() else "cpu"
print(f"Using device: {device}")
print(f"Normalization: {norm}")

#model = EDMPrecond((256, 128), 8, 3, label_dim=2, use_diffuse=False) #label_dim=2
#model = EDMPrecond((256, 128), 8, 3, label_dim=4) #label_dim=2
if norm == "linear":
    model = EDMPrecond((256, 128), 8, 3, label_dim=2)
elif norm == "cos_sin":
    model = EDMPrecond((256, 128), 8, 3, label_dim=4)
else:
    raise ValueError(f"Unknown normalization method: {norm}")

# Load the model
checkpoint = torch.load(model_path, map_location=device, weights_only=False)

# Case 1: full checkpoint with multiple keys
if isinstance(checkpoint, dict) and "model_state_dict" in checkpoint:
    print("Loading a full checkpoint")
    model.load_state_dict(checkpoint["model_state_dict"])

# Case 2: file contains weights only
else:
    print("Loading weights-only state_dict")
    model.load_state_dict(checkpoint)

model.to(device)
model.eval()

print("Model loaded and ready for inference.")





